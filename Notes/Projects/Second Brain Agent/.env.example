# Anthropic Claude API
ANTHROPIC_API_KEY=your_key_here

# Vault Configuration
VAULT_ROOT=/home/tan-hong-phong/Documents/obsidian/kepano-obsidian-main

# Optional: Obsidian Local REST API (for triggering refresh)
OBSIDIAN_API_URL=http://localhost:27123
OBSIDIAN_API_KEY=

# Agent Behavior
DRY_RUN=true
AUTO_COMMIT=false
REVIEW_MODE=auto

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/sba.log

# Safety Limits
MAX_BATCH_SIZE=50
BACKUP_ENABLED=true
CIRCUIT_BREAKER_ERROR_RATE=0.5

# Claude API Settings
ANTHROPIC_MODEL=claude-sonnet-4-7-20250514
MAX_TOKENS_PER_REQUEST=4000
EMBEDDING_MODEL=claude-3-embedding-3
